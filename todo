    <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 16px;">Restoring will overwrite current state. A new snapshot will be created before restoring.</p>
    <ul class="history-list" id="history-list"></ul>
    <div class="modal-actions">
      <button class="btn-modal btn-cancel" id="history-close">Close</button>
    </div>
  </div>
</div>

<!-- Context Menu -->
<div class="context-menu" id="context-menu" role="menu">
  <button class="context-item" id="ctx-edit" role="menuitem">✏️ Edit</button>
  <button class="context-item" id="ctx-duplicate" role="menuitem">📋 Duplicate</button>
  <button class="context-item" id="ctx-block" role="menuitem">🚫 Toggle Block</button>
  <button class="context-item" id="ctx-complete" role="menuitem">✅ Toggle Complete</button>
  <button class="context-item danger" id="ctx-delete" role="menuitem">🗑️ Delete</button>
</div>

<!-- Toast for Undo -->
<div class="toast-container" id="toast" role="alert" aria-live="assertive">
  <span class="toast-msg">Task deleted</span>
  <button class="toast-undo" id="toast-undo">Undo</button>
</div>

<script>
  // Safe Storage Wrapper (Remains for safety, but Add to Home Screen enables full storage)
  const storage = {
    _memData: {},
    getItem(key) {
      try {
        return window.localStorage.getItem(key);
      } catch (e) {
        return this._memData[key] || null;
      }
    },
    setItem(key, value) {
      try {
        window.localStorage.setItem(key, value);
      } catch (e) {
        this._memData[key] = String(value);
      }
    }
  };

  // Utility Functions
  function generateUUID() {
    if (crypto && crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  function escapeHTML(str) {
    if (!str) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function debounce(func, wait) {
    let timeout;
    return function(...args) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(this, args), wait);
    };
  }

  function formatDate(ms) {
    if (!ms) return '';
    const d = new Date(ms);
    return new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).format(d);
  }

  function formatDateTime(ms) {
    if (!ms) return '';
    const d = new Date(ms);
    return new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }).format(d);
  }

  // Central State
  const state = {
    tasks: [],
    capture: { duration: null, workload: null, priority: null },
    editor: { id: null, duration: 2, workload: 2, priority: 2 },
    expandedNotes: new Set(),
    search: '',
    deletedTaskRef: null,
    undoTimer: null,
    ctxTargetId: null
  };

  // DOM Elements
  const DOM = {
    hTitle: document.getElementById('h-title'),
    hSub: document.getElementById('h-sub'),
    taskInput: document.getElementById('task-input'),
    addBtn: document.getElementById('add-btn'),
    activeContainer: document.getElementById('active-tasks'),
    completedContainer: document.getElementById('completed-tasks'),
    completedSection: document.getElementById('completed-section'),
    progFill: document.getElementById('prog-fill'),
    progText: document.getElementById('prog-text'),
    sortSelect: document.getElementById('sort-select'),
    searchInput: document.getElementById('search-input'),
    toast: document.getElementById('toast'),
    toastUndo: document.getElementById('toast-undo'),
    contextMenu: document.getElementById('context-menu'),
    
    // Modals
    editorModal: document.getElementById('editor-modal'),
    editTitle: document.getElementById('edit-title'),
    editNotes: document.getElementById('edit-notes'),
    editBlocked: document.getElementById('edit-blocked'),
    historyModal: document.getElementById('history-modal'),
    historyList: document.getElementById('history-list')
  };

  // Initialisation & Migration
  function init() {
    DOM.hTitle.textContent = storage.getItem('opex_title') || 'Operational Excellence';
    DOM.hSub.textContent = storage.getItem('opex_sub') || 'OpEx Staircase - Go / No-Go Checklist';

    let loaded = JSON.parse(storage.getItem('opex_tasks') || '[]');
    state.tasks = loaded.map(t => {
      const duration = t.duration || t.impact || 2;
      const workload = t.workload || t.effort || 2;
      return {
        id: t.id || generateUUID(),
        title: t.title || 'Untitled',
        notes: t.notes || '',
        duration: duration,
        workload: workload,
        priority: t.priority || t.urgency || 2,
        effort: duration + workload,
        blocked: t.blocked || false,
        completed: t.completed || false,
        createdAt: t.createdAt || t.timestamp || Date.now(),
        updatedAt: t.updatedAt || Date.now(),
        completedAt: t.completedAt || null,
        order: t.order || 0
      };
    });

    setupEventListeners();
    renderTasks();
  }

  // Snapshot Management
  function createSnapshot() {
    const snapshot = {
      version: 2,
      title: DOM.hTitle.textContent,
      subtitle: DOM.hSub.textContent,
      tasks: JSON.parse(JSON.stringify(state.tasks)),
      timestamp: Date.now()
    };
    let history = JSON.parse(storage.getItem('opex_history') || '[]');
    history.unshift(snapshot);
    if (history.length > 10) history = history.slice(0, 10);
    storage.setItem('opex_history', JSON.stringify(history));
  }

  function restoreSnapshot(index) {
    if (!confirm('Are you sure you want to restore this version? Current unsaved changes will be lost.')) return;
    createSnapshot(); // Backup current state before restoring
    
    let history = JSON.parse(storage.getItem('opex_history') || '[]');
    const target = history[index];
    if (target && target.tasks) {
      state.tasks = target.tasks;
      if (target.title) DOM.hTitle.textContent = target.title;
      if (target.subtitle) DOM.hSub.textContent = target.subtitle;
      saveState();
      renderTasks();
      closeModals();
    }
  }

  function saveState() {
    storage.setItem('opex_title', DOM.hTitle.textContent);
    storage.setItem('opex_sub', DOM.hSub.textContent);
    storage.setItem('opex_tasks', JSON.stringify(state.tasks));
  }

  // Core Render Logic
  function renderTasks() {
    DOM.activeContainer.innerHTML = '';
    DOM.completedContainer.innerHTML = '';
    
    const term = state.search.toLowerCase();
    const isMatch = (t) => t.title.toLowerCase().includes(term) || (t.notes && t.notes.toLowerCase().includes(term));
    
    let activeTasks = state.tasks.filter(t => !t.completed && isMatch(t));
    let completedTasks = state.tasks.filter(t => t.completed && isMatch(t));
    
    const sortVal = DOM.sortSelect.value;
    activeTasks.sort((a, b) => {
      if (a.blocked !== b.blocked) return a.blocked ? 1 : -1;
      if (sortVal === 'easy') {
        return (b.priority - a.priority) || (a.effort - b.effort);
      } else {
        return (b.priority - a.priority) || (b.effort - a.effort);
      }
    });

    completedTasks.sort((a, b) => (b.completedAt || 0) - (a.completedAt || 0));

    activeTasks.forEach(t => DOM.activeContainer.appendChild(createTaskCard(t)));
    completedTasks.forEach(t => DOM.completedContainer.appendChild(createTaskCard(t)));
    
    DOM.completedSection.style.display = completedTasks.length ? 'block' : 'none';

    // Update Progress
    const total = state.tasks.length;
    const completed = state.tasks.filter(t => t.completed).length;
    const pct = total === 0 ? 0 : Math.round((completed / total) * 100);
    DOM.progFill.style.width = `${pct}%`;
    DOM.progText.textContent = `${pct}% (${completed}/${total})`;
    DOM.progText.setAttribute('aria-label', `Progress: ${pct}%`);
  }

  function getLabel(val) {
    return val === 1 ? 'Low' : val === 2 ? 'Med' : 'High';
  }

  function createTaskCard(task) {
    const isExpanded = state.expandedNotes.has(task.id);
    
    const card = document.createElement('div');
    card.className = `task-card ${task.completed ? 'completed' : ''} ${task.blocked ? 'blocked' : ''}`;
    card.dataset.id = task.id;
    card.setAttribute('role', 'listitem');
    card.setAttribute('tabindex', '0');
    card.setAttribute('aria-label', `Task: ${escapeHTML(task.title)}`);

    let html = `
      <div class="task-top">
        <button class="check-btn interactive-elem" data-action="toggle-complete" aria-label="${task.completed ? 'Mark incomplete' : 'Mark complete'}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            ${task.completed ? '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>' : '<circle cx="12" cy="12" r="10"></circle>'}
          </svg>
        </button>
        <h4 class="task-title">${escapeHTML(task.title)} <span class="effort-badge">Effort: ${task.effort}</span></h4>
      </div>
    `;

    if (task.notes) {
      html += `
        <button class="notes-toggle interactive-elem" data-action="toggle-notes">
          ${isExpanded ? '▼' : '▶'} Notes
        </button>
        <div class="notes-area ${isExpanded ? 'expanded' : ''}">
          <textarea class="notes-textarea-inline interactive-elem" data-action="update-notes" placeholder="Notes...">${escapeHTML(task.notes)}</textarea>
        </div>
      `;
    }

    html += `
      <div class="task-bottom">
        <div class="task-triage-mini">
          <div class="t-row"><span class="t-label">Dur</span><span class="t-val val-${task.duration}">${getLabel(task.duration)}</span></div>
          <div class="t-row"><span class="t-label">Work</span><span class="t-val val-${task.workload}">${getLabel(task.workload)}</span></div>
          <div class="t-row"><span class="t-label">Prio</span><span class="t-val val-${task.priority}">${getLabel(task.priority)}</span></div>
        </div>
        ${!task.completed ? `
        <button class="block-btn interactive-elem" data-action="toggle-block">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"></polygon><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
          ${task.blocked ? 'Blocked' : 'Block'}
        </button>` : ''}
      </div>
    `;

    if (task.completed && task.completedAt) {
      html += `<span class="completed-date">Completed: ${formatDate(task.completedAt)}</span>`;
    }

    card.innerHTML = html;

    // Interactions Setup
    let longPressTimer;
    const startLongPress = (e) => {
      if(e.target.closest('.interactive-elem')) return; // Ignore long press on buttons
      longPressTimer = setTimeout(() => {
        showContextMenu(task.id, e);
      }, 600);
    };
    const cancelLongPress = () => clearTimeout(longPressTimer);

    card.addEventListener('touchstart', startLongPress, {passive: true});
    card.addEventListener('touchend', cancelLongPress);
    card.addEventListener('touchmove', cancelLongPress);
    card.addEventListener('mousedown', startLongPress);
    card.addEventListener('mouseup', cancelLongPress);
    card.addEventListener('mouseleave', cancelLongPress);

    card.addEventListener('click', (e) => {
      const actionBtn = e.target.closest('.interactive-elem');
      if (actionBtn) {
        e.stopPropagation();
        handleCardAction(task.id, actionBtn);
        return;
      }
      openEditor(task.id);
    });
    
    // Auto-save notes
    const inlineNotes = card.querySelector('.notes-textarea-inline');
    if(inlineNotes) {
      inlineNotes.addEventListener('input', debounce((e) => {
        const t = state.tasks.find(x => x.id === task.id);
        if(t) { t.notes = e.target.value; saveState(); }
      }, 500));
    }

    return card;
  }

  function handleCardAction(id, elem) {
    const action = elem.dataset.action;
    const task = state.tasks.find(t => t.id === id);
    if (!task) return;

    if (action === 'toggle-complete') {
      task.completed = !task.completed;
      task.completedAt = task.completed ? Date.now() : null;
      createSnapshot();
      saveState();
      renderTasks();
    } else if (action === 'toggle-block') {
      task.blocked = !task.blocked;
      createSnapshot();
      saveState();
      renderTasks();
    } else if (action === 'toggle-notes') {
      if (state.expandedNotes.has(id)) state.expandedNotes.delete(id);
      else state.expandedNotes.add(id);
      renderTasks(); // Quick re-render to toggle display
    }
  }

  // Group Button Selection Logic
  function setupGroupSelection(context, groupIds) {
    groupIds.forEach(type => {
      const group = document.getElementById(`${context}-${type}`);
      if(!group) return;
      group.addEventListener('click', (e) => {
        if (e.target.tagName !== 'BUTTON') return;
        
        group.querySelectorAll('button').forEach(b => {
            b.className = '';
            b.setAttribute('aria-pressed', 'false');
        });
        
        const val = parseInt(e.target.dataset.val);
        e.target.classList.add(`active-${val}`);
        e.target.setAttribute('aria-pressed', 'true');
        
        state[context][type] = val;
        
        if (context === 'capture') validateCapture();
      });
    });
  }

  function validateCapture() {
    const hasText = DOM.taskInput.value.trim().length > 0;
    const hasVals = state.capture.duration !== null && state.capture.workload !== null && state.capture.priority !== null;
    DOM.addBtn.disabled = !(hasText && hasVals);
  }

  function resetCaptureUI() {
    DOM.taskInput.value = '';
    state.capture = { duration: null, workload: null, priority: null };
    ['duration', 'workload', 'priority'].forEach(type => {
      document.querySelectorAll(`#capture-${type} button`).forEach(b => {
          b.className = '';
          b.setAttribute('aria-pressed', 'false');
      });
    });
    validateCapture();
  }

  // Event Listeners Setup
  function setupEventListeners() {
    // Header Auto-save
    const saveHeader = debounce(() => saveState(), 300);
    DOM.hTitle.addEventListener('input', saveHeader);
    DOM.hSub.addEventListener('input', saveHeader);

    // Capture
    setupGroupSelection('capture', ['duration', 'workload', 'priority']);
    DOM.taskInput.addEventListener('input', validateCapture);
    DOM.taskInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !DOM.addBtn.disabled) {
        e.preventDefault();
        DOM.addBtn.click();
      }
    });

    DOM.addBtn.addEventListener('click', () => {
      const newTask = {
        id: generateUUID(),
        title: DOM.taskInput.value.trim(),
        notes: '',
        duration: state.capture.duration,
        workload: state.capture.workload,
        priority: state.capture.priority,
        effort: state.capture.duration + state.capture.workload,
        blocked: false,
        completed: false,
        createdAt: Date.now(),
        updatedAt: Date.now(),
        completedAt: null,
        order: state.tasks.length
      };
      state.tasks.push(newTask);
      createSnapshot();
      saveState();
      resetCaptureUI();
      renderTasks();
    });

    // Search & Sort
    DOM.searchInput.addEventListener('input', debounce((e) => {
      state.search = e.target.value;
      renderTasks();
    }, 200));
    DOM.sortSelect.addEventListener('change', renderTasks);

    // Editor Modal
    setupGroupSelection('editor', ['duration', 'workload', 'priority']);
    document.getElementById('editor-cancel').addEventListener('click', closeModals);
    document.getElementById('editor-save').addEventListener('click', () => {
      const task = state.tasks.find(t => t.id === state.editor.id);
      if (task) {
        task.title = DOM.editTitle.value.trim() || 'Untitled';
        task.notes = DOM.editNotes.value;
        task.duration = state.editor.duration;
        task.workload = state.editor.workload;
        task.priority = state.editor.priority;
        task.effort = task.duration + task.workload;
        task.blocked = DOM.editBlocked.checked;
        task.updatedAt = Date.now();
        createSnapshot();
        saveState();
        renderTasks();
      }
      closeModals();
    });

    // Clear Completed
    document.getElementById('clear-btn').addEventListener('click', () => {
      if(confirm('Are you sure you want to clear all completed actions?')) {
        state.tasks = state.tasks.filter(t => !t.completed);
        createSnapshot();
        saveState();
        renderTasks();
      }
    });

    // Global Clicks (Close Context Menu)
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.context-menu') && DOM.contextMenu.classList.contains('active')) {
        closeContextMenu();
      }
    });
    
    // Context Menu Actions
    document.getElementById('ctx-edit').addEventListener('click', () => {
      openEditor(state.ctxTargetId);
      closeContextMenu();
    });
    document.getElementById('ctx-duplicate').addEventListener('click', () => {
      const source = state.tasks.find(t => t.id === state.ctxTargetId);
      if(source) {
        const dup = {...source, id: generateUUID(), title: source.title + ' (Copy)', createdAt: Date.now(), completed: false, completedAt: null};
        state.tasks.push(dup);
        createSnapshot();
        saveState();
        renderTasks();
      }
      closeContextMenu();
    });
    document.getElementById('ctx-block').addEventListener('click', () => {
      const task = state.tasks.find(t => t.id === state.ctxTargetId);
      if(task) {
        task.blocked = !task.blocked;
        createSnapshot();
        saveState();
        renderTasks();
      }
      closeContextMenu();
    });
    document.getElementById('ctx-complete').addEventListener('click', () => {
      const task = state.tasks.find(t => t.id === state.ctxTargetId);
      if(task) {
        task.completed = !task.completed;
        task.completedAt = task.completed ? Date.now() : null;
        createSnapshot();
        saveState();
        renderTasks();
      }
      closeContextMenu();
    });
    document.getElementById('ctx-delete').addEventListener('click', () => {
      deleteTaskWithUndo(state.ctxTargetId);
      closeContextMenu();
    });

    // Toast Undo
    DOM.toastUndo.addEventListener('click', () => {
      if(state.deletedTaskRef) {
        state.tasks.push(state.deletedTaskRef);
        state.deletedTaskRef = null;
        clearTimeout(state.undoTimer);
        DOM.toast.classList.remove('show');
        saveState();
        renderTasks();
      }
    });

    // History
    document.getElementById('btn-history').addEventListener('click', showHistory);
    document.getElementById('history-close').addEventListener('click', closeModals);

    // Backup & Restore
    document.getElementById('export-btn').addEventListener('click', () => {
      const backupData = {
        version: 2,
        title: DOM.hTitle.textContent,
        subtitle: DOM.hSub.textContent,
        tasks: state.tasks,
        exportedAt: Date.now()
      };
      const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(backupData, null, 2));
      const a = document.createElement('a');
      a.href = dataStr;
      a.download = `opex_backup_${new Date().toISOString().slice(0,10)}.json`;
      document.body.appendChild(a);
      a.click();
      a.remove();
    });

    document.getElementById('import-file').addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const imported = JSON.parse(e.target.result);
          let importedTasks = imported.tasks || imported; // handle v1 array-only format
          if (!Array.isArray(importedTasks)) throw new Error("Tasks must be an array");
          
          createSnapshot(); // Before changing state
          
          state.tasks = importedTasks.map(t => ({
             ...t,
             id: t.id || generateUUID(),
             effort: t.effort || ((t.duration || t.impact || 2) + (t.workload || t.effort || 2))
          }));
          
          if(imported.title) DOM.hTitle.textContent = imported.title;
          if(imported.subtitle) DOM.hSub.textContent = imported.subtitle;
          
          saveState();
          createSnapshot(); // After successful import
          renderTasks();
          alert('Backup successfully loaded!');
        } catch (err) {
          alert('Invalid backup format. State not changed.');
        }
      };
      reader.readAsText(file);
      e.target.value = ''; 
    });
  }

  // Modals & Popovers Management
  function openEditor(taskId) {
    const task = state.tasks.find(t => t.id === taskId);
    if (!task) return;
    
    state.editor.id = taskId;
    DOM.editTitle.value = task.title;
    DOM.editNotes.value = task.notes || '';
    DOM.editBlocked.checked = task.blocked;

    ['duration', 'workload', 'priority'].forEach(type => {
      const val = task[type];
      state.editor[type] = val;
      const group = document.getElementById(`edit-${type}`);
      group.querySelectorAll('button').forEach(b => {
        b.className = '';
        b.setAttribute('aria-pressed', 'false');
      });
      const activeBtn = group.querySelector(`button[data-val="${val}"]`);
      if(activeBtn) {
        activeBtn.classList.add(`active-${val}`);
        activeBtn.setAttribute('aria-pressed', 'true');
      }
    });

    DOM.editorModal.classList.add('active');
  }

  function showHistory() {
    const history = JSON.parse(storage.getItem('opex_history') || '[]');
    DOM.historyList.innerHTML = '';
    
    if (history.length === 0) {
      DOM.historyList.innerHTML = '<p style="color: var(--text-muted); font-size:14px;">No history snapshots available.</p>';
    } else {
      history.forEach((snap, idx) => {
        const li = document.createElement('li');
        li.className = 'history-item';
        li.innerHTML = `
          <div class="history-info">
            <strong>${escapeHTML(snap.title || 'Snapshot')}</strong>
            <span>${formatDateTime(snap.timestamp)} - ${snap.tasks.length} tasks</span>
          </div>
          <button class="btn-restore" onclick="restoreSnapshot(${idx})">Restore</button>
        `;
        DOM.historyList.appendChild(li);
      });
    }
    DOM.historyModal.classList.add('active');
  }

  function closeModals() {
    DOM.editorModal.classList.remove('active');
    DOM.historyModal.classList.remove('active');
  }

  function showContextMenu(id, event) {
    state.ctxTargetId = id;
    
    // Position menu near touch/click or fallback to center
    let x = event.clientX || (event.touches && event.touches[0].clientX) || window.innerWidth/2;
    let y = event.clientY || (event.touches && event.touches[0].clientY) || window.innerHeight/2;
    
    DOM.contextMenu.style.left = `${Math.min(x, window.innerWidth - 220)}px`;
    DOM.contextMenu.style.top = `${Math.min(y, window.innerHeight - 250)}px`;
    DOM.contextMenu.classList.add('active');
  }

  function closeContextMenu() {
    DOM.contextMenu.classList.remove('active');
    state.ctxTargetId = null;
  }

  function deleteTaskWithUndo(id) {
    const index = state.tasks.findIndex(t => t.id === id);
    if (index === -1) return;
    
    state.deletedTaskRef = state.tasks.splice(index, 1)[0];
    createSnapshot();
    saveState();
    renderTasks();
    
    DOM.toast.classList.add('show');
    clearTimeout(state.undoTimer);
    state.undoTimer = setTimeout(() => {
      DOM.toast.classList.remove('show');
      state.deletedTaskRef = null;
    }, 5000);
  }

  // Make functions available to inline handlers (only where absolutely necessary)
  window.restoreSnapshot = restoreSnapshot;

  // Boot
  document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>



